# ─── Copy this file to .env and fill in your values ─────────────────────────

# Anthropic Claude (recommended)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OR OpenAI (set LLM_PROVIDER=openai below)
# OPENAI_API_KEY=your_openai_api_key_here

# Which LLM backend to use: "anthropic" or "openai"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-haiku-20241022   # fast + cheap for a student project

# Embedding model (runs locally — no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Paths
VECTOR_DB_PATH=./rag/vector_store
DATABASE_PATH=./database/students.db
DOCS_UPLOAD_PATH=./sample_docs
LOG_PATH=./logs/app.log

# RAG chunking settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=4
